{
  "version": 2,
  "builds": [
    {
      "src": "api/contact.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "project-detail.html",
      "use": "@vercel/static"
    },
    {
      "src": "project-site.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "projects.js",
      "use": "@vercel/static"
    },
    {
      "src": "project-detail.js",
      "use": "@vercel/static"
    },
    {
      "src": "project-site.js",
      "use": "@vercel/static"
    },
    {
      "src": "projects-data.json",
      "use": "@vercel/static"
    },
    {
      "src": "asset/(.*)",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
